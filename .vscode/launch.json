{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-vv", "-s"],
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: Selected Test Function",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-vv", "-s", "-k", "${selectedText}"],
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}